---
// Admin page — passphrase-gated by the edge function, then Identity-gated here.
// Set Netlify Identity registration to "Invite only" so only named admins get accounts.
const title = "Admin — Bowerman";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>{title}</title>
    <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <style>
      *, *::before, *::after { box-sizing: border-box; }
      body {
        margin: 0; padding: 0 20px 60px;
        font: 16px/1.6 system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: #f8fafc; color: #0f172a;
      }
      .container { max-width: 800px; margin: 0 auto; }
      header {
        display: flex; align-items: center; justify-content: space-between;
        gap: 12px; padding: 24px 0 20px; border-bottom: 1px solid #e2e8f0; margin-bottom: 28px;
      }
      h1 { font-size: 1.4rem; margin: 0; }
      h2 { font-size: 1.1rem; margin: 24px 0 12px; color: #334155; }
      .btn {
        font: inherit; cursor: pointer; border-radius: 8px;
        border: 1px solid #cbd5e1; background: #fff;
        padding: 8px 16px; font-size: .9rem;
      }
      .btn-primary { background: #0ea5e9; border-color: #0ea5e9; color: #fff; }
      .btn-danger { color: #b91c1c; border-color: #fecaca; }
      .btn:disabled { opacity: .5; cursor: default; }
      .who { font-size: .85rem; color: #64748b; }
      ul { list-style: none; padding: 0; margin: 0; }
      li {
        display: flex; align-items: flex-start; justify-content: space-between;
        gap: 12px; padding: 14px 0; border-bottom: 1px solid #e2e8f0;
      }
      li:last-child { border-bottom: none; }
      .item-info strong { display: block; margin-bottom: 2px; }
      .meta { font-size: .82rem; color: #64748b; }
      #gate, .status-msg { color: #64748b; margin: 0; }
      .hidden { display: none !important; }
      .tab-bar { display: flex; gap: 8px; margin-bottom: 20px; }
      .tab {
        padding: 8px 16px; border-radius: 8px; border: 1px solid #e2e8f0;
        background: #fff; cursor: pointer; font: inherit; font-size: .9rem;
      }
      .tab.active { background: #0ea5e9; border-color: #0ea5e9; color: #fff; }
      .section { display: none; }
      .section.active { display: block; }
    </style>
  </head>
  <body>
    <div class="container">
      <header>
        <h1>Admin</h1>
        <div style="display:flex;align-items:center;gap:12px;">
          <span id="who" class="who"></span>
          <button id="auth-btn" class="btn btn-primary">Log in</button>
        </div>
      </header>

      <p id="gate">Log in with your admin account to manage content.</p>

      <div id="admin-ui" class="hidden">
        <div class="tab-bar">
          <button class="tab active" data-tab="events">Events</button>
          <button class="tab" data-tab="bulletin">Bulletin</button>
        </div>

        <div id="tab-events" class="section active">
          <h2>Published Events</h2>
          <p id="events-empty" class="status-msg hidden">No published events.</p>
          <ul id="events-list"></ul>
        </div>

        <div id="tab-bulletin" class="section">
          <h2>Published Bulletin Posts</h2>
          <p id="bulletin-empty" class="status-msg hidden">No published bulletin posts.</p>
          <ul id="bulletin-list"></ul>
        </div>
      </div>
    </div>

    <script is:inline>
      const identity = window.netlifyIdentity;
      const authBtn = document.getElementById("auth-btn");
      const whoEl = document.getElementById("who");
      const gateEl = document.getElementById("gate");
      const adminUi = document.getElementById("admin-ui");

      async function getToken() {
        const user = identity.currentUser();
        return user ? await user.jwt() : null;
      }

      async function loadItems(type) {
        const endpoint = type === "events" ? "/api/events" : "/api/bulletin";
        const listEl = document.getElementById(`${type}-list`);
        const emptyEl = document.getElementById(`${type}-empty`);
        listEl.innerHTML = '<li><span class="meta">Loading…</span></li>';
        try {
          const res = await fetch(endpoint);
          const items = await res.json();
          listEl.innerHTML = "";
          emptyEl.classList.toggle("hidden", items.length > 0);
          for (const item of items) {
            const li = document.createElement("li");
            const when = item.startDateTime
              ? new Date(item.startDateTime).toLocaleString()
              : item.createdAt ? new Date(item.createdAt).toLocaleString() : "";
            const subtitle = [item.category, when].filter(Boolean).join(" · ");
            li.innerHTML = `
              <div class="item-info">
                <strong></strong>
                <div class="meta"></div>
              </div>
              <button class="btn btn-danger">Remove</button>
            `;
            li.querySelector("strong").textContent = item.title || item.body?.slice(0, 60) || "(untitled)";
            li.querySelector(".meta").textContent = subtitle;
            const btn = li.querySelector("button");
            btn.addEventListener("click", () => removeItem(type, item.id, li, btn));
            listEl.appendChild(li);
          }
        } catch (e) {
          listEl.innerHTML = '<li><span class="meta">Failed to load.</span></li>';
        }
      }

      async function removeItem(type, id, li, btn) {
        if (!confirm(`Remove this ${type === "events" ? "event" : "bulletin post"}?`)) return;
        btn.disabled = true;
        const t = await getToken();
        const res = await fetch("/.netlify/functions/admin-remove", {
          method: "POST",
          headers: { "content-type": "application/json", Authorization: "Bearer " + t },
          body: JSON.stringify({ type, id }),
        });
        if (res.ok) {
          li.remove();
          const listEl = document.getElementById(`${type}-list`);
          document.getElementById(`${type}-empty`).classList.toggle("hidden", listEl.children.length > 0);
        } else {
          const { error } = await res.json().catch(() => ({}));
          alert(error || "Failed to remove");
          btn.disabled = false;
        }
      }

      function refresh() {
        const user = identity.currentUser();
        const loggedIn = !!user;
        whoEl.textContent = loggedIn ? (user.email || "") : "";
        authBtn.textContent = loggedIn ? "Log out" : "Log in";
        gateEl.classList.toggle("hidden", loggedIn);
        adminUi.classList.toggle("hidden", !loggedIn);
        if (loggedIn) {
          loadItems("events");
          loadItems("bulletin");
        }
      }

      // Tab switching
      document.querySelectorAll(".tab").forEach(tab => {
        tab.addEventListener("click", () => {
          document.querySelectorAll(".tab").forEach(t => t.classList.remove("active"));
          document.querySelectorAll(".section").forEach(s => s.classList.remove("active"));
          tab.classList.add("active");
          document.getElementById(`tab-${tab.dataset.tab}`).classList.add("active");
        });
      });

      authBtn.addEventListener("click", () => identity.currentUser() ? identity.logout() : identity.open());
      identity.on("init", refresh);
      identity.on("login", () => { identity.close(); refresh(); });
      identity.on("logout", refresh);
    </script>
  </body>
</html>
