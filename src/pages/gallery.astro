---
import Layout from "../layouts/Layout.astro";
import Nav from "../components/Nav.astro";

// Gallery is curated — photos are managed by admins via /admin.
// In v1, photos are stored as JSON in Netlify Blobs. We fetch them here.
let albums: any[] = [];
let fetchError = false;

try {
  const base = Astro.url.origin;
  const res = await fetch(`${base}/api/gallery`);
  if (res.ok) albums = await res.json();
} catch {
  fetchError = true;
}
---

<Layout title="Gallery" description="Photos from Bowerman neighborhood block parties, game watches, and community events.">
  <Nav slot="before-nav" />

  <div class="container" style="padding-top:36px;padding-bottom:60px;">
    <h1>Photo Gallery</h1>
    <p class="gallery-sub">Moments from neighborhood gatherings, past and present.</p>

    {fetchError && <p class="notice error">Couldn't load photos right now.</p>}

    {!fetchError && albums.length === 0 && (
      <div class="empty-state">
        <div class="empty-icon">📸</div>
        <p>No photos yet — check back after the next block party!</p>
        <p class="empty-note">Admins can add photos from the <a href="/admin">admin panel</a>.</p>
      </div>
    )}

    {albums.length > 0 && (
      <div class="albums">
        {albums.map((album: any) => (
          <section class="album">
            <h2 class="album-title">{album.title}</h2>
            {album.description && <p class="album-desc">{album.description}</p>}
            <div class="photo-grid">
              {album.photos?.map((photo: any) => (
                <figure class="photo-item">
                  <img
                    src={photo.url}
                    alt={photo.caption || album.title}
                    loading="lazy"
                    decoding="async"
                    width="400"
                    height="300"
                  />
                  {photo.caption && <figcaption>{photo.caption}</figcaption>}
                </figure>
              ))}
            </div>
          </section>
        ))}
      </div>
    )}
  </div>
</Layout>

<style>
  h1 { margin: 0 0 8px; font-size: 1.8rem; }
  .gallery-sub { margin: 0 0 32px; color: var(--text-muted); }
  .notice.error { background: #fff3e0; color: #b45309; border-radius: 8px; padding: 12px 16px; }

  .empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
  .empty-icon { font-size: 3rem; margin-bottom: 12px; }
  .empty-state p { margin: 0 0 8px; font-size: 1rem; }
  .empty-note { font-size: .85rem; }

  .album { margin-bottom: 48px; }
  .album-title { font-size: 1.2rem; margin: 0 0 4px; }
  .album-desc { color: var(--text-muted); font-size: .9rem; margin: 0 0 16px; }
  .photo-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 12px;
  }
  .photo-item {
    margin: 0; border-radius: var(--radius); overflow: hidden;
    box-shadow: var(--shadow); background: var(--bg-subtle);
  }
  .photo-item img {
    display: block; width: 100%; height: 200px; object-fit: cover;
    transition: transform .2s;
  }
  .photo-item:hover img { transform: scale(1.03); }
  figcaption {
    padding: 8px 10px; font-size: .8rem; color: var(--text-muted);
    border-top: 1px solid var(--border);
  }
</style>
